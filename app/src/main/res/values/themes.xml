<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.SDFormatter" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorPrimaryContainer">@color/primary_container</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/on_secondary</item>
        <item name="colorSecondaryContainer">@color/secondary_container</item>
        <item name="colorTertiary">@color/tertiary</item>
        <item name="colorTertiaryContainer">@color/tertiary_container</item>
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/on_error</item>
        <item name="colorErrorContainer">@color/error_container</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant</item>
        <item name="colorOutline">@color/outline</item>
        <item name="colorOutlineVariant">@color/outline_variant</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:windowBackground">@color/background</item>

        <!-- Material 3 component styles -->
        <item name="materialCardViewStyle">@style/CardStyle</item>
        <item name="materialButtonStyle">@style/FormatButtonStyle</item>

        <!-- Shape -->
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.SDFormatter.Large</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.SDFormatter.Medium</item>
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.SDFormatter.Small</item>
    </style>

    <style name="ShapeAppearance.SDFormatter.Large" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="ShapeAppearance.SDFormatter.Medium" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <style name="ShapeAppearance.SDFormatter.Small" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>

    <style name="CardStyle" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/surface_container</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/outline</item>
        <item name="strokeWidth">1dp</item>
        <item name="contentPadding">0dp</item>
    </style>

    <style name="FormatButtonStyle" parent="Widget.Material3.Button">
        <item name="cornerRadius">8dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Dialog theme -->
    <style name="Theme.SDFormatter.Dialog" parent="ThemeOverlay.Material3.Dialog">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorSurface">@color/surface_container_high</item>
        <item name="colorOnSurface">@color/on_surface</item>
    </style>
</resources>
